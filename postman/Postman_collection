{
  "info": {
    "name": "Particle API",
    "description": "API для веб-сервиса интерактивных визуализаций",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:3000"
    },
    {
      "key": "accessToken",
      "value": ""
    },
    {
      "key": "presetId",
      "value": ""
    }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const response = pm.response.json();",
                  "if (response.id) {",
                  "    pm.test('User registered', () => {",
                  "        pm.expect(response.email).to.equal('test@example.com');",
                  "    });",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/v1/auth/register",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"test@example.com\",\n  \"password\": \"123456\"\n}"
            }
          }
        },
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const response = pm.response.json();",
                  "if (response.accessToken) {",
                  "    pm.environment.set('accessToken', response.accessToken);",
                  "    pm.test('Token received', () => {",
                  "        pm.expect(response.accessToken).to.be.a('string');",
                  "    });",
                  "}",
                  "if (response.user) {",
                  "    pm.test('User data', () => {",
                  "        pm.expect(response.user.email).to.equal('test@example.com');",
                  "    });",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/v1/auth/login",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"test@example.com\",\n  \"password\": \"123456\"\n}"
            }
          }
        }
      ]
    },
    {
      "name": "Users",
      "item": [
        {
          "name": "Get Current User",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/v1/users/me",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }]
          }
        }
      ]
    },
    {
      "name": "Presets",
      "item": [
        {
          "name": "Get Public Feed",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/v1/presets/public"
          }
        },
        {
          "name": "Get My Presets",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/v1/presets",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }]
          }
        },
        {
          "name": "Create Preset",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const response = pm.response.json();",
                  "if (response.id) {",
                  "    pm.environment.set('presetId', response.id.toString());",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/v1/presets",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Космический поток\",\n  \"config\": {\n    \"particleCount\": 5000,\n    \"colors\": [\"#1a1a2e\", \"#16213e\"]\n  },\n  \"isPublic\": false\n}"
            }
          }
        },
        {
          "name": "Get Preset By ID",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/v1/presets/{{presetId}}",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }]
          }
        },
        {
          "name": "Update Preset",
          "request": {
            "method": "PUT",
            "url": "{{baseUrl}}/api/v1/presets/{{presetId}}",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Обновлённый пресет\",\n  \"config\": {\n    \"particleCount\": 10000\n  }\n}"
            }
          }
        },
        {
          "name": "Make Preset Public",
          "request": {
            "method": "PATCH",
            "url": "{{baseUrl}}/api/v1/presets/{{presetId}}/public",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"isPublic\": true\n}"
            }
          }
        },
        {
          "name": "Delete Preset",
          "request": {
            "method": "DELETE",
            "url": "{{baseUrl}}/api/v1/presets/{{presetId}}",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }]
          }
        }
      ]
    },
    {
      "name": "Likes",
      "item": [
        {
          "name": "Like Preset",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/v1/presets/{{presetId}}/like",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }]
          }
        },
        {
          "name": "Unlike Preset",
          "request": {
            "method": "DELETE",
            "url": "{{baseUrl}}/api/v1/presets/{{presetId}}/like",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }]
          }
        }
      ]
    },
    {
      "name": "Comments",
      "item": [
        {
          "name": "Get Comments",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/v1/presets/{{presetId}}/comments"
          }
        },
        {
          "name": "Create Comment",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const response = pm.response.json();",
                  "if (response.id) {",
                  "    pm.environment.set('commentId', response.id.toString());",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/v1/presets/{{presetId}}/comments",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"text\": \"Красивая визуализация!\"\n}"
            }
          }
        },
        {
          "name": "Update Comment",
          "request": {
            "method": "PUT",
            "url": "{{baseUrl}}/api/v1/comments/{{commentId}}",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"text\": \"Обновлённый комментарий\"\n}"
            }
          }
        },
        {
          "name": "Delete Comment",
          "request": {
            "method": "DELETE",
            "url": "{{baseUrl}}/api/v1/comments/{{commentId}}",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }]
          }
        }
      ]
    }
  ]
}